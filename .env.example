# Database: backend's own Postgres (terminals, schools, students, attendance_events, meal_events).
# Option 1 - Neon (free, no Supabase DB password needed): https://neon.tech → Create project → Copy connection string.
# Option 2 - Supabase: Project Settings → Database → Connection string (Session/Transaction pooler URI).
# Option 3 - Local: postgres://farmtopalm:farmtopalm_secret@localhost:5432/farmtopalm (with Docker Postgres).
# Use SUPABASE_DATABASE_URL in Railway to override auto-injected DATABASE_URL (from linked Postgres).
DATABASE_URL=postgres://farmtopalm:farmtopalm_secret@localhost:5432/farmtopalm

# JWT signing (change in production)
JWT_SECRET=change-me-in-production

# 32-byte hex key for biometric template encryption
BIOMETRIC_ENC_KEY=0123456789abcdef0123456789abcdef

# Public URL of this backend — devices use this by default (no manual link on device).
# The Android app reads this from .env at build time. Set to your deployed URL.
# Local: http://10.0.2.2:3000 (emulator) or http://YOUR_LAN_IP:3000 (physical device). Railway: https://your-app.up.railway.app
BACKEND_PUBLIC_URL=http://10.0.2.2:3000
# (Optional) API_BASE_URL=http://localhost:3000

# SupaSchool Supabase: for writing device attendance/meal records (optional; bridge disabled if unset)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key (use service_role, NOT anon key)
# SUPABASE_SCHOOL_ID=uuid-of-school-in-supabase (override when Neon school_id ≠ Supabase; get from Supabase Table Editor → schools)

PORT=3000
