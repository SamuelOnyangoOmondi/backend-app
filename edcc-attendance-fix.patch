+                f.get(raw)
+            } catch (_: Throwable) { null } ?: continue
+            when (value) {
+                is ByteArray -> return value
+                is java.nio.ByteBuffer -> {
+                    return try {
+                        val dup = value.duplicate()
+                        val bytes = ByteArray(dup.remaining())
+                        dup.get(bytes)
+                        bytes
+                    } catch (_: Throwable) { null }
+                }
+                else -> { }
+            }
+        }
+        return null
+    }
 
